@model BespokeSoftware.Models.PermissionVM

@{
    ViewBag.Title = "Role Permission";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="card border border-info">

    <h3 class="bg-info text-center p-2 fw-bold">
        Role Permission
    </h3>

    <div class="card-body">

        <!-- Role Dropdown -->
        <div class="row mb-3">
            <div class="col-sm-4">
                <label class="fw-bold">Select Role :</label>

                @Html.DropDownListFor(m => m.RoleId,
                    Model.RoleList,
                    "-- Select Role --",
                    new { @class = "form-control", id = "ddlRole" })
            </div>
        </div>

        <!-- Permission Table -->
        <table class="table table-bordered text-center">
            <thead class="bg-info">
                <tr>
                    <th>Add</th>
                    <th>Update</th>
                    <th>Delete</th>
                    <th>List</th>
                    <th>View</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <td><input type="checkbox" id="chkAdd" /></td>
                    <td><input type="checkbox" id="chkUpdate" /></td>
                    <td><input type="checkbox" id="chkDelete" /></td>
                    <td><input type="checkbox" id="chkList" /></td>
                    <td><input type="checkbox" id="chkView" /></td>
                </tr>
            </tbody>
        </table>

        <div class="text-center mt-4">
            <button class="btn btn-primary px-4 fw-bold text-white"
                    onclick="SavePermissions()">
                Save
            </button>
        </div>
        <hr />

        <h5 class="text-center fw-bold mt-3">Role Permission List</h5>

        <table class="table table-bordered text-center mt-2" id="tblRolePermission">
            <thead class="bg-info">
                <tr>
                    <th>Role</th>
                    <th>Add</th>
                    <th>Update</th>
                    <th>Delete</th>
                    <th>List</th>
                    <th>View</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.RolePermissionList != null)
                {
                    foreach (var item in Model.RolePermissionList)
                    {
                        <tr>
                            <td>@item.RoleName</td>
                            <td>@(item.Add ? "✔️" : "❌")</td>
                            <td>@(item.Update ? "✔️" : "❌")</td>
                            <td>@(item.Delete ? "✔️" : "❌")</td>
                            <td>@(item.List ? "✔️" : "❌")</td>
                            <td>@(item.View ? "✔️" : "❌")</td>

                        </tr>
                    }
                }
            </tbody>

        </table>
    </div>
</div>



<script>

    $('#ddlRole').change(function () {

    var roleId = $(this).val();

    $('#chkAdd').prop('checked', false);
    $('#chkUpdate').prop('checked', false);
    $('#chkDelete').prop('checked', false);
    $('#chkList').prop('checked', false);

    if (roleId == "") return;

    $.get('/MasterData/GetRolePermissions', { roleId: roleId }, function (data) {

    data.forEach(function (item) {

    if (item.permissionName == "Add")
    $('#chkAdd').prop('checked', item.isAllowed);

    if (item.permissionName == "Update")
    $('#chkUpdate').prop('checked', item.isAllowed);

    if (item.permissionName == "Delete")
    $('#chkDelete').prop('checked', item.isAllowed);

    if (item.permissionName == "List")
    $('#chkList').prop('checked', item.isAllowed);

    if (item.permissionName == "View")
    $('#chkView').prop('checked', item.isAllowed);

    });


    });

    });

    function SavePermissions() {

    var roleId = $('#ddlRole').val();

    if (roleId == "") {
    Swal.fire("Please select role first", "", "warning");
    return;
    }

    var data = {
    RoleId: roleId,
    Add: $('#chkAdd').is(':checked'),
    Update: $('#chkUpdate').is(':checked'),
    Delete: $('#chkDelete').is(':checked'),
    List: $('#chkList').is(':checked'),
    View: $('#chkView').is(':checked')
    };

    $.post('/MasterData/SaveRolePermissions', data, function (res) {


    Swal.fire(res.message, '', res.type);
    window.location.href = '/MasterData/RolePermission';

    }).fail(function () {

    Swal.fire("Something went wrong!", "", "error");

    });

    }



   
</script>