@model BespokeSoftware.Models.Department

@{
    ViewBag.Title = "Department";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<style>

    div.dataTables_filter {
        margin-bottom: 15px;
    }

    #deptTable {
        margin-top: 10px;
    }

    #deptTable th,
    #deptTable td {
        border: 1px solid #ccc !important;
    }

    #deptTable tbody tr:hover {
        background-color: #e6f2ff;
    }

    .form-box {
        border: 2px solid #6c757d;
        border-radius: 6px;
        padding: 15px;
        margin-top: 10px;
        width: 85%; /* left-right कमी करण्यासाठी */
        margin-left: auto;
        margin-right: auto;
    }

</style>
@{
    var sweetAlertMessage = TempData["SweetAlertMessage"] as string;
    var sweetAlertOptions = TempData["SweetAlertOptions"] as string;
}
@if (!string.IsNullOrEmpty(sweetAlertMessage))
{
    <script>
        Swal.fire('@sweetAlertMessage', '', '@sweetAlertOptions');
    </script>
}
@using (Html.BeginForm())
{

    @Html.HiddenFor(m => m.DepID)

    <div class="card border border-info">

        <h3 class="bg-info text-black text-center p-2 fw-bold">
            Department Management
        </h3>

        <div class="card-body mt-4">

            <div class="form-box">

                <div class="row justify-content-center p-3">

                    <div class="col-sm-2"></div>

                    <div class="col-sm-4">

                        <label class="fw-bold">Department :</label>

                        @Html.TextBoxFor(m => m.DepartmentName,
                        new { @class = "form-control", required = "required" })

                </div>

                <div class="col-sm-4">

                    <label class="fw-bold">Status :</label>

                    @Html.DropDownListFor(m => m.IsDelete,
                                        new List<SelectListItem>
                                        {
                                        new SelectListItem{Text="Active",Value="false"},
                                        new SelectListItem{Text="Inactive",Value="true"}
                                        },
                                        new { @class = "form-control form-select" })

                </div>

                <div class="col-sm-2"></div>

            </div>

            <div class="text-center mt-4">

                <button type="submit" class="btn btn-primary px-4 fw-bold">
                    Save
                </button>

            </div>
        </div>



        <hr />

        <table id="deptTable" class="table table-bordered table-hover text-center">

            <thead class="bg-info text-black">

                <tr>
                    <th class="text-center">ID</th>
                    <th class="text-center">Department</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Action</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.DepartmentList)
                    {
                        <tr>

                            <td>@item.DepID</td>

                            <td>@item.DepartmentName</td>

                            <td>
                                @(item.IsDelete ? "Inactive" : "Active")
                            </td>

                            <td>

                                <a href="@Url.Action("Department","MasterData",
                                   new { id = item.DepID })"
                           class="btn btn-info btn-sm fw-bold">

                                    Edit

                                </a>

                            </td>

                        </tr>
                                }

                </tbody>

            </table>

        </div>

    </div>

}
<script>

    $(document).ready(function () {

        $('#deptTable').DataTable({

            pageLength: 5,

            lengthMenu: [5, 10, 20, 50],

            ordering: true,

            searching: true,

            columnDefs: [
                { orderable: false, targets: 3 } // Action column sort disable
            ]

        });

    });

</script>