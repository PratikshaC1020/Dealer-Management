@model List<BespokeSoftware.Models.Person>
@{
    ViewBag.Title = "PersonList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>

@{
    var sweetAlertMessage = TempData["SweetAlertMessage"] as string;
    var sweetAlertOptions = TempData["SweetAlertOptions"] as string;
}
@if (!string.IsNullOrEmpty(sweetAlertMessage))
{
    <script>
        Swal.fire('@sweetAlertMessage', '', '@sweetAlertOptions');
    </script>
}

<div class="card border border-info">
    <div class="card-header">
        <h4 class="bg-info text-center fw-bold p-2 text-black">Person List</h4>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end m-4 ">
            <a asp-controller="MasterData"
               asp-action="Person"
               class="btn btn-success fw-bold">
                + Add Person
            </a>
        </div>
        <table id="personTable" class="table table-bordered table-striped mt-2">
            <thead class="table-info text-center mt-2">
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Gender</th>
                    <th>Aadhaar</th>
                    <th>PAN</th>
                    <th>Type</th>
                    <th>Communication</th>
                    <th>Address</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" width="50" />
                            }
                        </td>

                        <td>
                            @item.Title @item.FirstName @item.MiddleName @item.LastName
                        </td>

                        <td>@item.Gender</td>
                        <td>@item.AadhaarNo</td>
                        <td>@item.PANNo</td>
                        <td>@item.PersonType</td>

                        <td class="text-center">
                            <button class="btn btn-sm btn-info fw-bold"
                                    onclick="showCommunication(@item.Id)">
                                View
                            </button>
                        </td>

                        <td class="text-center">
                            <button class="btn btn-sm btn-warning fw-bold"
                                    onclick="showAddress(@item.Id)">
                                View
                            </button>
                        </td>
                        <td class="text-center">

                            <!-- UPDATE -->
                            <a asp-controller="MasterData"
                               asp-action="EditPerson"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-info fw-bold me-2">
                                Update
                            </a>

                            <!-- DELETE -->
                            <button class="btn btn-sm btn-danger fw-bold"
                                    onclick="deletePerson(@item.Id)">
                                Delete
                            </button>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="modal fade" id="commModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header bg-info text-white">
                        <h5 class="modal-title">Communication</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body" id="commBody">
                        <!-- data here -->
                    </div>

                </div>
            </div>
        </div>
        <div class="modal fade" id="addrModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title">Address</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body" id="addrBody">
                        <!-- data here -->
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

       function showCommunication(id){

        $.get('/MasterData/GetCommunication?id=' + id, function(data){

            let html = "";

            data.forEach(x => {
                html += `<p><b>${x.communicationType}</b> : ${x.value}</p>`;
            });

            $("#commBody").html(html);

            var modal = new bootstrap.Modal(document.getElementById('commModal'));
            modal.show();
        });
    }

        function showAddress(id){

        $.get('/MasterData/GetAddress?id=' + id, function(data){

            let html = "";

            data.forEach(x => {
                html += `<p><b>${x.addressType}</b> : ${x.addressLine}</p>`;
            });

            $("#addrBody").html(html);

            var modal = new bootstrap.Modal(document.getElementById('addrModal'));
            modal.show();
        });
    }

</script>
<script>
    $(document).ready(function () {

        $('#personTable').DataTable({
            paging: true,
            searching: true,
            ordering: true,
            info: true,
            pageLength: 10,
            lengthMenu: [10, 25, 50, 100],
        });

    });
</script>
<script>
    function deletePerson(id){

        if(confirm("Are you sure you want to delete this person?")){
            window.location.href = '/MasterData/DeletePerson/' + id;
        }

    }
</script>