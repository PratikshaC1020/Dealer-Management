@model BespokeSoftware.Models.DealerModels.DealerFullViewModel

<style>
    .section-title {
        color: #0dcaf0;
        font-weight: bold;
    }

    .section-box {
        border: 1px solid #0dcaf0;
        border-radius: 8px;
        padding: 12px;
        background: #f8fcff;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    /* 🔥 SCROLL LOGIC */
    .inner-scroll {
        max-height: 220px;
        overflow-y: auto;
        padding-right: 5px;
    }

    /* item box */
    .box {
        border: 1px solid #dee2e6;
        padding: 8px;
        border-radius: 6px;
        background: #fff;
        margin-bottom: 8px;
    }

    img {
        object-fit: cover;
    }
    .img-thumb{
    width:100%;
    height:100px;
    object-fit:cover;
    border-radius:6px;
    cursor:pointer;
    border:1px solid #ddd;
    transition:0.2s;
}

.img-thumb:hover{
    transform:scale(1.05);
}
.nav-tabs .nav-link {
    color: #0dcaf0;
    font-weight: 500;
    border: 1px solid transparent;
}

.nav-tabs .nav-link:hover {
    background-color: #e6f7fb;
}

.nav-tabs .nav-link.active {
    background-color: #0dcaf0 !important;  
    color: white !important;
    border-color: #0dcaf0 #0dcaf0 white;
    border-radius: 6px 6px 0 0;
}

    .img-thumb {
        width: 100%;
        height: 80px; 
        object-fit: cover;
        border-radius: 6px;
        cursor: pointer;
        border: 1px solid #ddd;
        transition: 0.2s;
    }

        .img-thumb:hover {
            transform: scale(1.05);
        }
</style>

<div class="card border-info">

    <div class="card-header text-center fw-bold bg-info text-white">
        View Dealer Information
    </div>

    <div class="card-body">

        <!-- ================= DEALER INFO ================= -->
        <div class="section-box mb-3">
            <div class="text-end mt-3">
                <button type="button" class="btn btn-secondary"x
                        onclick="location.href='@Url.Action("Index", "Dealer")'">
                    Go Back
                </button>
            </div>
    <h5 class="section-title">Dealer Information</h5>

            <div class="row g-3">

                <!-- LEFT SIDE (DETAILS) -->
                <div class="col-md-9">

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label>Dealer Name</label>
                            <input class="form-control" value="@Model.Dealer?.DealerName" readonly />
                        </div>

                        <div class="col-md-4">
                            <label>Owner Name</label>
                            <input class="form-control" value="@Model.Dealer?.OwnerName" readonly />
                        </div>

                        <div class="col-md-4">
                            <label>GST</label>
                            <input class="form-control" value="@Model.Dealer?.GSTNo" readonly />
                        </div>

                        <div class="col-md-4">
                            <label>PAN</label>
                            <input class="form-control" value="@Model.Dealer?.PANNo" readonly />
                        </div>

                        <div class="col-md-4">
                            <label>Credit Terms</label>
                            <input class="form-control" value="@Model.Dealer?.PaymentMode" readonly />
                        </div>

                        <div class="col-md-4">
                            <label>Weekly Off</label>
                            <input class="form-control" value="@Model.Dealer?.WeeklyOff" readonly />
                        </div>

                    </div>

                </div>

                <div class="col-md-3">

                    <div class="text-center">

                        <div class="d-flex gap-2">

                            <!-- DEALER IMAGE -->
                            <div style="width:50%;">
                                @{
                                    var dealerImg = Model.Images
                                        .FirstOrDefault(x => x.Type == "Dealer")?.ImageBase64;
                                }

                                <img src="@(string.IsNullOrEmpty(dealerImg) ? "/images/no-image.png" : dealerImg)"
                                     class="img-fluid rounded border"
                                     style="height:120px; width:100%; object-fit:cover; cursor:pointer;"
                                     onclick="openImagePreview(this.src)" />

                                <small class="d-block mt-1 fw-bold text-muted">Main Dealer</small>
                            </div>

                            <!-- OWNER IMAGE -->
                            <div style="width:50%;">
                              @{
                                    var owner = Model.Persons.FirstOrDefault(x => x.PersonType == "Owner");

                                    var ownerImg = Model.Images
                                        .FirstOrDefault(x => x.Type == "Person" && owner != null && x.IdentityID == owner.PersonID)
                                        ?.ImageBase64;
                                }

                                <img src="@(string.IsNullOrEmpty(ownerImg) ? "/images/no-image.png" : ownerImg)"
                                     class="img-fluid rounded border"
                                     style="height:120px; width:100%; object-fit:cover; cursor:pointer;"
                                     onclick="openImagePreview(this.src)" />

                                <small class="d-block mt-1 fw-bold text-muted">Owner</small>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

</div>

       
        <div class="row mb-3">

            <div class="col-md-12">

                <!-- NOTES -->
                <div class="section-box mb-3" id="notesSection">
                    <div class="d-flex justify-content-between align-items-center mb-2">

                        <h5 class="section-title mb-0">Notes</h5>

                        <!-- ✅ BUTTON GROUP -->
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-success" onclick="openNoteModal()">
                                + Add
                            </button>

                            <button class="btn btn-sm btn-primary" onclick="openPrintNotes()">
                                🖨 Print
                            </button>
                        </div>

                    </div>

                    @{
                        var categories = Model.Notes
                            .GroupBy(x => new { x.CategoryId, x.CategoryName })
                            .ToList();
                    }

   
                    <ul class="nav nav-tabs mb-2">
                        @for (int i = 0; i < categories.Count; i++)
                        {
                            <li class="nav-item">
                                <button class="nav-link @(i == 0 ? "active" : "")"
                                        data-bs-toggle="tab"
                                        data-bs-target="#tab_@categories[i].Key.CategoryId">
                                    @categories[i].Key.CategoryName
                                </button>
                            </li>
                        }
                    </ul>

   
                    <div class="tab-content inner-scroll">

                        @for (int i = 0; i < categories.Count; i++)
                        {
                            var cat = categories[i];

                            <div class="tab-pane fade @(i == 0 ? "show active" : "")"
                                    id="tab_@cat.Key.CategoryId">

                                @foreach (var note in cat)
                                {
                                    <div class="box">
                                        <div class="row g-2 align-items-center">
                                            <!-- NOTE DATE -->
                                            <div class="col-md-2">
                                                <label class="fw-bold">Date</label>
                                                <input class="form-control"
                                                       value="@note.NoteDate?.ToString("dd-MM-yyyy")"
                                                       readonly />
                                            </div>

                                            <!-- NOTE FOR -->
                                            <div class="col-md-3">
                                                <label class="fw-bold">Note For</label>
                                                <input class="form-control"
                                                       value="@note.NoteFor"
                                                       readonly />
                                            </div>

                                            <!-- NOTE TEXT -->
                                            <div class="col-md-7">
                                                <label class="fw-bold">Note</label>
                                                <textarea class="form-control" rows="1" readonly style="resize:none; overflow:hidden;">
                                                @note.NoteText</textarea>
                                            </div>

                                        </div>
                                    </div>
                                }

                            </div>
                        }

                    </div>

                </div>
            </div>

            <div class="col-md-12">
               
                <!-- DEALER ADDRESS (HIDDEN DEFAULT) -->
               
                <div class="section-box mb-3">
                    <!-- HEADER LINE -->
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="section-title mb-0">Dealer Address</h5>

                        <button class="btn btn-sm btn-info" onclick="toggleAddress(this)">
                            View Address
                        </button>
                    </div>
                    <div id="dealerAddressSection" style="display:none;">
                        <div class="inner-scroll">
                            @foreach (var addr in Model.Addresses)
                            {
                                <div class="box">
                                    <input class="form-control mb-1" value="@addr.AddressType" readonly />
                                    <input class="form-control" value="@addr.AddressLine" readonly />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-12">
                <div class="section-box">

                    <!-- HEADER -->
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="section-title mb-0">Images</h5>

                        <button class="btn btn-sm btn-info" onclick="toggleImages(this)">
                            View Images
                        </button>
                    </div>

                    <div id="imageSection" style="display:none;">
                        <div class="row inner-scroll">
                          @foreach (var img in Model.Images.Where(x => x.Type == "Dealer"))
                            {
                                <div class="col-md-2 mb-2">

                                    @{
                                        var imagePath = img.ImageBase64;
                                    }

                                    <img src="@(string.IsNullOrEmpty(imagePath)
                                                                 ? "/images/no-image.png"
                                                                 : imagePath)"
                                     class="img-thumb"
                                     onclick="openImagePreview(this.src)" />

                                </div>
                                                        }
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="section-box">

            <!-- HEADER -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="section-title mb-0">Person Details</h5>

                <button class="btn btn-sm btn-info" onclick="togglePerson(this)">
                    View Details
                </button>
            </div>

            <!-- TOGGLE CONTENT -->
            <div id="personSection" style="display:none;">
                <div class="inner-scroll">

                    @foreach (var p in Model.Persons)
                    {
                        <div class="box">

                            <h6 class="fw-bold text-info mb-2">
                                @p.Title @p.FirstName @p.MiddleName @p.LastName
                            </h6>

                            <div class="row">

                                <div class="col-md-4">
                                    <label class="fw-bold">Gender :</label> @p.Gender
                                </div>

                                <div class="col-md-4">
                                    <label class="fw-bold">DOB :</label> @p.DOB?.ToString("dd-MM-yyyy")
                                </div>

                                <div class="col-md-4">
                                    <label class="fw-bold">Anniversary :</label> @p.AnniversaryDate?.ToString("dd-MM-yyyy")
                                </div>

                                <div class="col-md-4">
                                    <label class="fw-bold">PAN :</label> @p.PANNo
                                </div>

                                <div class="col-md-4">
                                    <label class="fw-bold">Person Type :</label> @p.PersonType
                                </div>

                                <div class="col-md-12">
                                    <label class="fw-bold">Remark :</label> @p.Remark
                                </div>

                            </div>

                            <hr />
                            <div class="fw-bold">Addresses</div>
                            @foreach (var pa in Model.PersonAddresses.Where(x => x.PersonID == p.PersonID))
                            {
                                <div>📍 @pa.AddressLine</div>
                            }

                            <div class="fw-bold mt-2">Communications</div>
                            @foreach (var c in Model.Communications.Where(x => x.PersonID == p.PersonID))
                            {
                                <div>📞 @c.Value</div>
                            }

                            <hr />
                            <div class="fw-bold">Images</div>

                           <div class="row">
                            @foreach (var img in Model.Images
                                .Where(x => x.IdentityID == p.PersonID && x.Type == "Person"))
                            {
                                <div class="col-md-3 mb-2">
                                    <img src="@(string.IsNullOrEmpty(img.ImageBase64) 
                                        ? "/images/no-image.png" 
                                        : "data:image/png;base64," + img.ImageBase64)"
                                         class="img-thumb"
                                         onclick="openImagePreview(this.src)" />
                                </div>
                            }
                        </div>

                        </div>
                    }

                </div>
            </div>

        </div>
            </div>

        </div>

   
<input type="hidden" id="dealerId" value="@Model.Dealer?.DealerId" />

 <div class="modal fade" id="imagePreviewModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-info text-white">
                <h5>Image Preview</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <img id="previewImg" class="img-fluid rounded"/>
            </div>

        </div>
    </div>
</div>
<div class="modal fade" id="noteModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-info text-white">
                <h5>Add Note</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- CATEGORY -->
                <div class="mb-2">
                    <label>Category *</label>
                    <div class="d-flex gap-2">

                        <select id="noteCategory" class="form-control">
                            <option value="">-- Select --</option>
                            @foreach (var c in Model.Categories)
                            {
                                <option value="@c.CategoryId">@c.CategoryName</option>
                            }
                        </select>

                        <!-- ADD CATEGORY BUTTON -->
                        <button class="btn btn-info" onclick="openCategoryModal()">+</button>
                    </div>
                </div>

                <!-- NOTE FOR -->
                <div class="mb-2">
                    <label>Note For</label>
                    <input type="text" id="noteFor" class="form-control" />
                </div>

                <!-- DATE -->
                <div class="mb-2">
                    <label>Date</label>
                    <input type="date" id="noteDate" class="form-control" />
                </div>

                <!-- NOTE -->
                <div class="mb-2">
                    <label>Note</label>
                    <textarea id="noteText" class="form-control"></textarea>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-success" onclick="saveNote()">Save</button>
            </div>

        </div>
    </div>
</div>
<div class="modal fade" id="categoryModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-info text-white">
                <h5>Add Category</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <label>Category Name *</label>
                <input type="text" id="newCategory" class="form-control" />
            </div>

            <div class="modal-footer">
                <button class="btn btn-success" onclick="saveCategory()">Add</button>
            </div>

        </div>
    </div>
</div>

<script>
function openImagePreview(src){
    document.getElementById("previewImg").src = src;
    new bootstrap.Modal(document.getElementById('imagePreviewModal')).show();
}

    function openPrintNotes() {

        var dealerId = document.getElementById("dealerId").value;

        if (!dealerId) {
            alert("DealerId not found");
            return;
        }

        // ✅ controller call
        window.open('/Dealer/PrintNotes?dealerId=' + dealerId, '_blank');
    }
</script>

<script>
    function toggleAddress(btn) {
        var section = document.getElementById("dealerAddressSection");

        if (section.style.display === "none") {
            section.style.display = "block";
            btn.innerText = "Hide Address";
        } else {
            section.style.display = "none";
            btn.innerText = "View Address";
        }
    }
        function toggleImages(btn) {
        var section = document.getElementById("imageSection");

        if (section.style.display === "none") {
            section.style.display = "block";
            btn.innerText = "Hide Images";
        } else {
            section.style.display = "none";
            btn.innerText = "View Images";
        }
    }
        function togglePerson(btn) {
        var section = document.getElementById("personSection");

        if (section.style.display === "none") {
            section.style.display = "block";
            btn.innerText = "Hide Details";
        } else {
            section.style.display = "none";
            btn.innerText = "View Details";
        }
    }
        function openNoteModal() {
        new bootstrap.Modal(document.getElementById('noteModal')).show();
    }

    function openCategoryModal() {
        new bootstrap.Modal(document.getElementById('categoryModal')).show();
    }

    // SAVE CATEGORY
    function saveCategory() {
        var name = document.getElementById("newCategory").value;

        if (!name) {
            alert("Category required");
            return;
        }

        $.post('/Dealer/AddCategoryView', { name: name }, function (res) {

            // dropdown update without refresh
            $("#noteCategory").append(
                `<option value="${res.id}" selected>${res.name}</option>`
            );

            bootstrap.Modal.getInstance(document.getElementById('categoryModal')).hide();
            document.getElementById("newCategory").value = "";
        });
    }

    // SAVE NOTE
        function saveNote() {

        var data = {
            DealerId: $("#dealerId").val(),   // ✅ ADD THIS
            CategoryId: $("#noteCategory").val(),
            NoteFor: $("#noteFor").val(),
            NoteDate: $("#noteDate").val(),
            NoteText: $("#noteText").val()
        };

        if (!data.CategoryId) {
            alert("Category is required");
            return;
        }

        $.post('/Dealer/AddNote', data, function (res) {
            location.reload();
        });
    }
</script>