@model BespokeSoftware.Models.Dealer.DealerViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<style>
.section-title{color:#0dcaf0;font-weight:bold;}
.section-box{
    border:1px solid #0dcaf0;
    border-radius:8px;
    padding:12px;
    background:#f8fcff;
    box-shadow:0 2px 6px rgba(0,0,0,0.05);
}
.inner-scroll{max-height:300px;overflow-y:auto;}
.box{
    border:1px solid #dee2e6;
    padding:8px;
    border-radius:6px;
    background:#fff;
    position:relative;
    margin-bottom:8px;
}
.remove{position:absolute;top:5px;right:8px;cursor:pointer;}

.add-icon{
    color:#0dcaf0;
    font-size:20px;
    cursor:pointer;
    transition:0.2s;
}
.add-icon:hover{transform:scale(1.2);}
.error-msg{
    color:#dc3545;
    font-size:13px;
    margin-top:2px;
}

</style>

<div class="card border-info">

<div class="card-header text-center fw-bold bg-info text-white">
Add Dealer
</div>

<div class="card-body">

<form id="dealerForm" method="post">

<!-- ================= DEALER INFO ================= -->
<div class="section-box mb-3">

<h5 class="section-title">Dealer Information</h5>

<div class="row g-3">

<div class="col-md-3">
<label>Dealer Name</label>
<input name="Dealer.DealerName" class="form-control"/>
</div>

<div class="col-md-3">
<label>Owner Name</label>
<input name="Dealer.OwnerName" class="form-control"/>
</div>

<div class="col-md-3">
<label>GST</label>
<input name="Dealer.GSTNo" class="form-control"/>
</div>

<div class="col-md-3">
<label>PAN</label>
<input name="Dealer.PANNo" class="form-control"/>
</div>

<div class="col-md-3">
<label>Payment Mode</label>
<select name="Dealer.DefaultPaymentModeId" class="form-select">
<option>Select</option>
@foreach(var p in ViewBag.PaymentModeList){
<option value="@p.ID">@p.PaymentModeName</option>
}
</select>
</div>

<div class="col-md-3">
<label>Weekly Off</label>
<select name="Dealer.WeeklyOffDayId" class="form-select">
<option>Select</option>
@foreach(var w in ViewBag.WeeklyOffList){
<option value="@w.ID">@w.Day</option>
}
</select>
</div>

</div>
</div>

<!-- ================= ADDRESS + NOTES ================= -->
<div class="row mb-3">

    <!-- ADDRESS (SMALL) -->
    <div class="col-md-4">
        <div class="section-box">
            <div class="d-flex justify-content-between">
                <h5 class="section-title">Dealer Address</h5>
                <i class="bi bi-plus-circle-fill add-icon" onclick="addDealerAddress()"></i>
            </div>
            <div id="dealerAddressContainer" class="inner-scroll"></div>
        </div>
    </div>

    <!-- NOTES (BIG) -->
    <div class="col-md-8">
        <div class="section-box">
            <div class="d-flex justify-content-between">
                <h5 class="section-title">Notes</h5>
                <i class="bi bi-plus-circle-fill add-icon" onclick="addNote()"></i>
            </div>
            <div id="notesContainer" class="inner-scroll notes-big"></div>
        </div>
    </div>

</div>

<!-- ================= IMAGES + PERSON ================= -->
<div class="row mb-3">

<div class="col-md-4">
<div class="section-box">
<div class="d-flex justify-content-between">
<h5 class="section-title">Images</h5>
<i class="bi bi-plus-circle-fill add-icon" onclick="openImageModal()"></i>
</div>
<div id="imageGrid" class="row inner-scroll"></div>
</div>
</div>

<div class="col-md-8">
<div class="section-box">
<div class="d-flex justify-content-between">
<h5 class="section-title">Person Details</h5>
<i class="bi bi-plus-circle-fill add-icon" onclick="openPersonModal()"></i>
</div>
<div id="personGrid" class="inner-scroll"></div>
</div>
</div>

</div>

<div class="text-center">
<button class="btn btn-info px-4 fw-bold">Save Dealer</button>
</div>

</form>

</div>
</div>

<!-- ================= IMAGE MODAL ================= -->
<div class="modal fade" id="imageModal">
<div class="modal-dialog">
<div class="modal-content">
<div class="modal-header bg-info text-white">
<h5>Add Images</h5>
<button class="btn-close" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body">
<input type="file" id="multiImageInput" multiple class="form-control"/>
</div>
<div class="modal-footer">
<button class="btn btn-info" onclick="saveImages()">Add</button>
</div>
</div>
</div>
</div>

<!-- ================= PERSON MODAL ================= -->
<div class="modal fade" id="personModal">
<div class="modal-dialog modal-xl">
<div class="modal-content">

<div class="modal-header bg-info text-white">
<h5>Add Person</h5>
<button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">

    <div class="row g-2">

        <!-- ROW 1 -->
        <div class="col-md-3">
    <label class="fw-bold">Title</label>
    <select id="pTitle" class="form-control">
        <option value="">Select</option>
        <option value="Mr">Mr</option>
        <option value="Mrs">Mrs</option>
        <option value="Miss">Miss</option>
        <option value="Ms">Ms</option>
        
    </select>
</div>

        <div class="col-md-3">
            <label class="fw-bold">First Name</label>
            <input id="pFirst" class="form-control" placeholder="First Name"/>
        </div>

        <div class="col-md-3">
            <label class="fw-bold">Middle Name</label>
            <input id="pMiddle" class="form-control" placeholder="Middle Name"/>
        </div>

        <div class="col-md-3">
            <label class="fw-bold">Last Name</label>
            <input id="pLast" class="form-control" placeholder="Last Name"/>
        </div>

        <!-- ROW 2 -->
        <div class="col-md-3">
            <label class="fw-bold">Gender</label>
            <select id="pGender" class="form-control">
                <option value="">Select</option>
                <option>Male</option>
                <option>Female</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="fw-bold">Date Of Birth</label>
            <input type="date" id="pDOB" class="form-control"/>
        </div>

        <div class="col-md-3">
            <label class="fw-bold">Anniversary Date</label>
            <input type="date" id="pAnniversary" class="form-control"/>
        </div>

        <div class="col-md-3">
            <label class="fw-bold">PAN</label>
            <input id="pPAN" class="form-control" placeholder="PAN"/>
        </div>

        <!-- ROW 3 -->
        <div class="col-md-6">
            <label class="fw-bold">Designation</label>
            <input id="pType" class="form-control" placeholder="Designation"/>
        </div>

        <div class="col-md-6">
    <label class="fw-bold">Remark</label>
    <input id="pRemark" class="form-control" placeholder="Remark"/>
</div>

    </div>

    <!-- ================= COMMUNICATION ================= -->
    <h6 class="text-info mt-3 d-flex justify-content-between">
        Communication
        <i class="bi bi-plus-circle-fill add-icon" onclick="addComm()"></i>
    </h6>

    <div id="commContainer"></div>

    <!-- ================= ADDRESS ================= -->
    <h6 class="text-info mt-3 d-flex justify-content-between">
        Address
        <i class="bi bi-plus-circle-fill add-icon" onclick="addPersonAddress()"></i>
    </h6>

    <div id="personAddressContainer"></div>

</div>

<div class="modal-footer">
<button class="btn btn-info" onclick="savePerson()">Save</button>
</div>

</div>
</div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>

// ADDRESS
var dIndex=0;
function addDealerAddress(){
$("#dealerAddressContainer").append(`

<div class="box">

    <i class="bi bi-x-circle text-danger remove"
       onclick="$(this).parent().remove()"></i>

    <!-- TYPE -->
    <input name="DealerAddresses[${dIndex}].AddressType"
           class="form-control mb-1"
           placeholder="Type"/>

    <!-- ADDRESS -->
    <input name="DealerAddresses[${dIndex}].AddressLine"
           class="form-control"
           placeholder="Enter address"/>

</div>

`);
dIndex++;
}

// NOTES
var noteIndex=0;
function addNote(){
$("#notesContainer").append(`
<div class="box">
<i class="bi bi-x-circle text-danger remove" onclick="$(this).parent().remove()"></i>
<select name="DealerNotes[${noteIndex}].CategoryId" class="form-control mb-1">
<option value="">Select Notes Category</option>${getCategoryOptions()}
</select>
<textarea name="DealerNotes[${noteIndex}].NoteText" class="form-control"></textarea>
</div>`);
noteIndex++;
}

function getCategoryOptions(){
var options='';
@foreach(var c in ViewBag.CategoryList){
<text>options+=`<option value="@c.ID">@c.CategoryName</option>`;</text>
}
return options;
}

// IMAGE

// OPEN MODAL
function openImageModal(){

    // ✅ CLEAR OLD FILES
    $("#multiImageInput").val("");

    $("#imageModal").modal('show');
}


// SAVE IMAGES
function saveImages(){

    let input = $("#multiImageInput")[0];
    let files = input.files;

    // ✅ VALIDATION
    if(files.length === 0){
        alert("Please select at least one image");
        return;
    }

    for(let i=0; i<files.length; i++){

        // ✅ IMAGE TYPE VALIDATION
        if(!files[i].type.startsWith("image/")){
            alert("Only image files allowed");
            return;
        }

        let reader = new FileReader();

        reader.onload = function(e){

            $("#imageGrid").append(`
                <div class="col-md-3 mb-2">

                    <div class="position-relative">

                        <img src="${e.target.result}" class="img-fluid rounded">

                        <!-- REMOVE -->
                        <i class="bi bi-x-circle text-danger"
                           style="position:absolute; top:5px; right:5px; cursor:pointer;"
                           onclick="$(this).parent().parent().remove()">
                        </i>

                    </div>

                </div>
            `);
        };

        reader.readAsDataURL(files[i]);
    }

    // ✅ CLEAR AFTER SAVE
    $("#multiImageInput").val("");

    $("#imageModal").modal('hide');
}

// PERSON
var personList=[];
function openPersonModal(){ $("#personModal").modal('show'); }

function addComm(){
$("#commContainer").append(`

<div class="box">

    <i class="bi bi-x-circle text-danger remove"
       onclick="$(this).parent().remove()"></i>

    <div class="row g-2">

        <!-- TYPE -->
        <div class="col-md-4">
            <label class="fw-bold">Type</label>
            <select class="form-control">
                <option value="">Select</option>
                <option>Mobile</option>
                <option>Email</option>
                <option>Landline</option>
            </select>
        </div>

        <!-- LABEL -->
        <div class="col-md-4">
            <label class="fw-bold">Communication Label</label>
            <input type="text" class="form-control"
                   placeholder="EX: Personal / Official / WhatsApp" >
        </div>

        <!-- VALUE -->
        <div class="col-md-4">
            <label class="fw-bold">Value</label>
            <input type="text" class="form-control"
                   placeholder="Enter value"/>
        </div>

    </div>

</div>

`);
}

function addPersonAddress(){
$("#personAddressContainer").append(`

<div class="box">

    <i class="bi bi-x-circle text-danger remove"
       onclick="$(this).parent().remove()"></i>

    <div class="row g-2">

        <!-- TYPE -->
        <div class="col-md-4">
            <label class="fw-bold">Type</label>
            <input type="text" class="form-control"
                   />
        </div>

        <!-- ADDRESS -->
        <div class="col-md-8">
            <label class="fw-bold">Address</label>
            <input type="text" class="form-control"
                   placeholder="Enter address"/>
        </div>

    </div>

</div>

`);
}

function savePerson(){

    let isValid = true;

    // remove old errors
    $(".error-msg").remove();

    function setError(el, msg){
        el.after(`<div class="error-msg">${msg}</div>`);
        isValid = false;
    }

    let title = $("#pTitle");
    let first = $("#pFirst");
    let middle = $("#pMiddle");
    let last = $("#pLast");
    let gender = $("#pGender");
    let pan = $("#pPAN");
    let type = $("#pType");  

    // REQUIRED VALIDATION
    if(title.val() === "") setError(title, "Title is required");
    if(first.val().trim() === "") setError(first, "First name is required");
    if(middle.val().trim() === "") setError(middle, "Middle name is required");
    if(last.val().trim() === "") setError(last, "Last name is required");
    if(gender.val() === "") setError(gender, "Gender is required");
    if(type.val().trim() === "") setError(type, "Designation is required");
    // PAN VALIDATION
    let panVal = pan.val().toUpperCase();
    let panRegex = /^[A-Z]{5}[0-9]{4}[A-Z]{1}$/;

    if(panVal === ""){
        setError(pan, "PAN is required");
    }
    else if(!panRegex.test(panVal)){
        setError(pan, "Invalid PAN format");
    }

    if(!isValid) return;

    // ================= ORIGINAL LOGIC =================
    let p={
        title:title.val(),
        first:first.val(),
        middle:$("#pMiddle").val(),
        last:last.val(),
        gender:gender.val(),
        dob:$("#pDOB").val(),
        anniversary:$("#pAnniversary").val(),
        pan:panVal,
        type:$("#pType").val(),
        remark:$("#pRemark").val(),
        communications:[],
        addresses:[]
    };

   $("#commContainer .box").each(function(){

    let type = $(this).find("select").val();
    let label = $(this).find("input").eq(0).val();
    let value = $(this).find("input").eq(1).val();

    p.communications.push({
        type: type,
        label: label,
        value: value
    });

});

    $("#personAddressContainer .box").each(function(){

    let type = $(this).find("input").eq(0).val();
    let address = $(this).find("input").eq(1).val();

    p.addresses.push({
        type: type,
        address: address
    });

});

    personList.push(p);
    renderPersonGrid();

    // clear form
    $("#personModal input, #personModal textarea").val("");
    $("#personModal select").val("");
    $("#commContainer").empty();
    $("#personAddressContainer").empty();

    $("#personModal").modal('hide');
}
function renderPersonGrid(){
$("#personGrid").empty();

personList.forEach((p,i)=>{

let comm="",addr="";
p.communications.forEach(c=>{
    comm+=`<div>• ${c.type} (${c.label}): ${c.value}</div>`;
});
p.addresses.forEach(a=>{addr+=`<div>• ${a.type}: ${a.address}</div>`});

$("#personGrid").append(`
<div class="card mb-2 border-info">
<div class="card-body">
<b>${p.first} ${p.last}</b><br>
${comm}<hr>${addr}
<button class="btn btn-sm btn-danger float-end" onclick="removePerson(${i})">Remove</button>
</div>
</div>
`);
});
}

function removePerson(i){
personList.splice(i,1);
renderPersonGrid();
}

</script>