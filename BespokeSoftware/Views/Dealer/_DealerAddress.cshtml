@model List<BespokeSoftware.Models.Dealer.Address>

@if (Model.Count > 0)
{
    <table class="table table-bordered">
        <tr>
            <th>Type</th>
            <th>Address</th>
        </tr>

        @foreach (var a in Model)
        {
            <tr>
                <td>@a.AddressType</td>
                <td>@a.AddressLine</td>
            </tr>
        }
    </table>
}
else
{
    <p class="text-danger">No Address Found</p>
}