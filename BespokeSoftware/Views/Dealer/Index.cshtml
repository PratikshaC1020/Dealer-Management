@model IEnumerable<BespokeSoftware.Models.Dealer>

@{
ViewBag.Title = "Dealer";
Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<!-- ✅ REQUIRED -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    #dealerTable th, #dealerTable td {
        border: 1px solid #ccc !important;
    }

    #dealerTable tbody tr:hover {
        background-color: #e6f2ff;
    }

    .img-box {
        width:50px;
        height:50px;
        border-radius:6px;
        object-fit:cover;
    }

    /* Switch container */
    .switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 26px;
    }

        /* Hide default checkbox */
        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    /* Slider */
    .slider {
        position: absolute;
        cursor: pointer;
        background-color: #ccc;
        transition: .4s;
        border-radius: 34px;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
    }

        /* Circle */
        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

    /* Checked */
    input:checked + .slider {
        background-color: #2196F3;
    }

        input:checked + .slider:before {
            transform: translateX(24px);
        }
</style>

<div class="card border border-info">
<h2 class="bg-info text-black text-center fw-bold p-2">
    Dealer List
</h2>

<div class="card-body">

    <div class="text-end mb-3">
        @* <a href="/Dealer/_AddEditDealer" target="_blank" class="btn btn-info fw-bold">
            Add Dealer <i class="bi bi-plus"></i>
        </a> *@

            @if (User.IsInRole("Admin") || User.IsInRole("Supervisor"))
            {
                <a href="/Dealer/_AddEditDealer" target="_blank" class="btn btn-info fw-bold">
                    Add Dealer<i class="bi bi-plus"></i>
                </a>
            }
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover" id="dealerTable">

            <thead class="bg-info text-black">
                <tr>
                   @*  <th>Code</th> *@
                    <th>Name</th>
                    <th>Owner</th>
                   @*  <th>Payment</th>
                    <th>Weekly Off</th>
                    <th>Dealer Img</th>
                    <th>Company Img</th> *@
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                       @*  <td>@item.DealerCode</td> *@
                        <td>@item.DealerName</td>
                        <td>@item.OwnerName</td>
                       @*  <td>@item.PaymentMode</td>
                        <td>@item.WeeklyOff</td>

                        <!-- Dealer Image -->
                        <td>
                            <img src="data:image/png;base64,@item.DealerImage"
                                 class="img-box" />
                        </td>

                        <!-- Company Image -->
                        <td>
                            <img src="data:image/png;base64,@item.CompanyImage"
                                 class="img-box" />
                        </td> *@

                            <td class="text-center">
                                <label class="switch">
                                    <input type="checkbox"
                                           class="status-toggle"
                                           data-id="@item.DealerId"
                                           @(item.IsActive ? "checked" : "") />
                                    <span class="slider round"></span>
                                </label>
                            </td>

                        <td class="text-center">

                           @*  <a href="/Dealer/EditDealer/@item.DealerId" class="btn btn-info btn-sm">
                                <i class="bi bi-pencil-square"></i>
                            </a> *@
                                @if (User.IsInRole("Admin") || User.IsInRole("Supervisor"))
                                {
                                    <a href="/Dealer/EditDealer/@item.DealerId" class="btn btn-info btn-sm">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                }

                              @*   <a href="javascript:void(0);"
                                       onclick="DeleteDealer(@item.DealerId)"
                                       class="btn btn-danger btn-sm"
                                       data-bs-toggle="tooltip"
                                       data-bs-placement="top"
                                       title="Delete Dealer">
    
                                    <i class="bi bi-trash"></i>
                                </a> *@
                                @if (User.IsInRole("Admin"))
                                {
                                    <a href="javascript:void(0);"
                                           onclick="DeleteDealer(@item.DealerId)"
                                           class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }

                            @* <button class="btn btn-primary btn-sm"
                                <a href="@Url.Action("EditDealer", "Dealer", new { id = item.DealerId })"
                                   class="btn btn-info btn-sm">
                                    Edit
                                </a>
                            <a href="javascript:void(0);" onclick="DeleteDealer(@item.DealerId)" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </a>

                            <button class="btn btn-primary btn-sm"
                                    onclick="ViewAddress(@item.DealerId)">
                                <i class="bi bi-geo-alt"></i>
                            </button>

                            <button class="btn btn-success btn-sm"
                                    onclick="ViewPerson(@item.DealerId)">
                                <i class="bi bi-people"></i>
                            </button>

                            <button class="btn btn-warning btn-sm"
                                    onclick="ViewNotes(@item.DealerId)">
                                <i class="bi bi-stickies"></i>
                            </button> *@
                                <button class="btn btn-info btn-sm"
                                        onclick="viewDealer(@item.DealerId)"
                                        data-bs-toggle="tooltip"
                                        data-bs-placement="top"
                                        title="View Dealer Information">
                                    <i class="bi bi-eye"></i>
                                </button>

                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>

</div>

<!-- ADDRESS MODAL -->

<div class="modal fade" id="addressModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info">
                <h5 class="fw-bold text-black">Address</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="addressBody"></div>
        </div>
    </div>
</div>

<!-- PERSON MODAL -->

<div class="modal fade" id="commModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5>Person List</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="commBody"></div>
        </div>
    </div>
</div>

<!-- NOTES MODAL -->

<div class="modal fade" id="notesModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5>Notes</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="notesBody"></div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>

    // DATATABLE
    $(document).ready(function () {
        $('#dealerTable').DataTable({
    paging: true,
    searching: true,
    ordering: true,
    info: true,
    pageLength: 10,
    lengthMenu: [10, 25, 50, 100],
        });
    });

    // ADDRESS
    function ViewAddress(id){
        $.get('/Dealer/GetDealerAddress',{dealerId:id},function(data){
            $("#addressBody").html(data);
            new bootstrap.Modal(document.getElementById('addressModal')).show();
        });
    }

    // PERSON
    function ViewPerson(id){
        $.get('/Dealer/GetDealerCommunication',{dealerId:id},function(data){
            $("#commBody").html(data);
            new bootstrap.Modal(document.getElementById('commModal')).show();
        });
    }

    // NOTES
    function ViewNotes(id){
        $.get('/Dealer/GetDealerNotes',{dealerId:id},function(data){
            $("#notesBody").html(data);
            new bootstrap.Modal(document.getElementById('notesModal')).show();
        });
    }



    function viewDealer(id) {
    window.location.href = '/Dealer/ViewDealerDetails?dealerId=' + id;
    }

    // DELETE
    function DeleteDealer(id){
        Swal.fire({
            title: 'Delete?',
            text: "Are you sure?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes'
        }).then((result)=>{
            if(result.isConfirmed){
                window.location.href = '/Dealer/DeleteDealer/' + id;
            }
        });
    }


    function DeleteDealer(id) {

    Swal.fire({
    title: 'Are you sure?',
    text: "You want to delete this dealer!",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#d33',
    cancelButtonColor: '#3085d6',
    confirmButtonText: 'Delete',
    cancelButtonText: 'Cancel'
    }).then((result) => {

    if (result.isConfirmed) {

    $.ajax({
    url: '/Dealer/Delete',
    type: 'POST',
    data: { dealerId: id },
    success: function (res) {

    if (res.success) {
    Swal.fire(
    'Deleted!',
    res.message,
    'success'
    ).then(() => {
    location.reload();
    });
    }
    else {
    Swal.fire(
    'Error!',
    res.message,
    'error'
    );
    }
    },
    error: function () {
    Swal.fire(
    'Error!',
    'Something went wrong!',
    'error'
    );
    }
    });

    }

    });
    }

        $(document).on("change", ".status-toggle", function () {

    let checkbox = $(this);
    let dealerId = checkbox.data("id");
    let isChecked = checkbox.is(":checked");

    let statusText = isChecked ? "Active" : "Blacklisted";

    Swal.fire({
    title: 'Are you sure?',
    text: "Change status to " + statusText,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Yes'
    }).then((result) => {

    if (result.isConfirmed) {

    $.ajax({
    url: '/Dealer/UpdateDealerStatus',
    type: 'POST',
    data: {
    id: dealerId,
    isActive: isChecked
    },
    success: function (res) {
    if (res.success) {
    Swal.fire('Updated!', '', 'success');
    } else {
    checkbox.prop("checked", !isChecked); // revert
    }
    },
    error: function () {
    checkbox.prop("checked", !isChecked); // revert
    }
    });

    } else {
    checkbox.prop("checked", !isChecked); // revert if cancel
    }
    });
    });

</script>
