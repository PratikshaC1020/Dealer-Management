@model List<BespokeSoftware.Models.Dealer.Person>

@if (Model != null && Model.Count > 0)
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Person Name</th>
                <th>Type</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.PersonName</td>
                    <td>@p.PersonTYpe</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-danger">No Person Found</p>
}