@model List<BespokeSoftware.Models.Dealer.NoteVM>

@if (Model.Count > 0)
{
    <table class="table table-bordered">
        <tr>
            <th>Category</th>
            <th>Note</th>
        </tr>

        @foreach (var n in Model)
        {
            <tr>
                <td>@n.CategoryName</td>
                <td>@n.NoteText</td>
            </tr>
        }
    </table>
}
else
{
    <p class="text-danger">No Notes Found</p>
}